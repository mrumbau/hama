# server/.env.example — copy to server/.env (gitignored) and fill in.
# Server-side secrets only. Frontend .env (client/.env) holds only PUBLIC values.

NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ── Supabase (3 keys, never mix them) ────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
# Service-role key: server-only, bypasses RLS. NEVER ship to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# JWT secret: used to verify access tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=...

# ── Postgres direct connection (Drizzle migrations) ──────────────────────────
# Use the pooled URL for the server runtime, the direct URL only for migrations.
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── ML service ───────────────────────────────────────────────────────────────
ML_BASE_URL=http://127.0.0.1:8001
REDIS_URL=redis://127.0.0.1:6379

# ── External APIs (4 services, never reach the browser) ──────────────────────
SERPAPI_KEY=...
PICARTA_API_KEY=...
REALITY_DEFENDER_API_KEY=...

# ── Cost guard (per operator per day, EUR) ──────────────────────────────────
COST_GUARD_DAILY_EUR=2.0

# ── Circuit breaker ─────────────────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_OPEN_MS=60000
