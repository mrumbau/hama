# server/.env.production.example
#
# Copy this into Render's environment-variable panel for the
# `chaw-server` web service. Do NOT commit a .env.production file —
# secrets live only in the Render dashboard.
#
# A separate Supabase project lives in Frankfurt (eu-central-1) for
# project-chaw.net; the dev Mumbai project keeps the .env.example
# fixtures at the root.

NODE_ENV=production
LOG_LEVEL=info
# Render injects PORT — DO NOT set it here. The Express server reads
# process.env.PORT and binds 0.0.0.0:PORT on production.

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated. Wildcard "*" is intentionally NOT supported because
# the API ships JWT credentials per request.
CORS_ORIGINS=https://project-chaw.net,https://www.project-chaw.net

# ── Supabase Frankfurt project ──────────────────────────────────────────────
# Each value comes from the Frankfurt project's Settings → API + Database
# panes. The values below are placeholders.
SUPABASE_URL=https://<FRANKFURT_PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<FRANKFURT_SERVICE_ROLE_KEY>
SUPABASE_JWT_SECRET=<FRANKFURT_JWT_SECRET_OR_LEAVE_BLANK_IF_USING_JWKS>

# ── Postgres connections ────────────────────────────────────────────────────
# Pooled URL for runtime (port 6543), direct URL for migrations (5432).
SUPABASE_DB_PASSWORD=<FRANKFURT_DB_PASSWORD>
DATABASE_URL=postgresql://postgres.<FRANKFURT_PROJECT_REF>:<FRANKFURT_DB_PASSWORD>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql://postgres:<FRANKFURT_DB_PASSWORD>@db.<FRANKFURT_PROJECT_REF>.supabase.co:5432/postgres

# ── ML service + Redis on Render ────────────────────────────────────────────
# ML_BASE_URL is the internal Render URL of the chaw-ml service (use the
# `*.onrender.com` host that Render assigns; internal-network URL works
# inside a single Render team). Falls back to public if mis-set.
ML_BASE_URL=https://chaw-ml.onrender.com
ML_TIMEOUT_MS=15000
# Render-managed Redis instance — Render exposes this as REDIS_URL when
# you attach the Key-Value addon to the service.
REDIS_URL=<RENDER_REDIS_URL>

# ── External APIs ───────────────────────────────────────────────────────────
SERPAPI_KEY=<SERPAPI_KEY>
PICARTA_API_KEY=<PICARTA_KEY>
REALITY_DEFENDER_API_KEY=<RD_KEY>
REALITY_DEFENDER_BASE_URL=https://api.prd.realitydefender.xyz
REALITY_DEFENDER_TIMEOUT_MS=20000

# CRITICAL: Reality Defender stays in mock mode for the live demo.
# The 50-scan/month free tier would burn out within hours of a public
# URL going live with even a small click-through. Real-mode requires
# a paid tier + a manual audit; do NOT flip without one.
RD_MOCK_MODE=true

# ── POI enrolment limits ────────────────────────────────────────────────────
POI_PHOTO_MAX_BYTES=52428800
POI_PHOTOS_MAX_PER_REQUEST=1

# ── Cost guard (per operator per UTC day, EUR) ──────────────────────────────
# €2.00 covers ~15 Sniper runs/day per operator. With an open demo
# (any signup) this caps a single attacker's burn at €2 before they're
# rate-limited until 00:00 UTC.
COST_GUARD_DAILY_EUR=2.0

# ── Per-layer costs (Tag 8b defaults — adjust to actual provider rates) ────
LAYER_COST_WEB_PRESENCE_EUR=0.02
LAYER_COST_GEOGRAPHIC_EUR=0.01
LAYER_COST_AUTHENTICITY_EUR=0.10

# ── Circuit breaker ─────────────────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_OPEN_MS=60000
