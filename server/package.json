{
  "name": "@argus/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run"
  },
  "dependencies": {
    "@argus/shared": "workspace:*",
    "@supabase/supabase-js": "^2.46.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.3",
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "p-limit": "^7.3.0",
    "p-queue": "^8.0.1",
    "p-retry": "^7.1.1",
    "pg": "^8.18.0",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.27",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
