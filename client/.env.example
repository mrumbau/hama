# client/.env.example — copy to client/.env.local (gitignored) and fill in.
#
# Only VITE_-prefixed values reach the browser. They MUST be safe to expose:
#   ✓ Supabase URL + anon key (RLS protects everything)
#   ✗ service-role key, JWT secret, external API keys

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
