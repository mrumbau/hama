# client/.env.production.example
#
# Copy these into Vercel's environment-variable panel for the production
# deployment of project-chaw.net (Settings → Environment Variables →
# Production scope). Only VITE_-prefixed values are bundled into the
# client JS — they MUST be safe to expose:
#   ✓ Supabase URL + anon key (RLS protects every operator's rows)
#   ✓ Express API URL (public regardless)
#   ✗ service-role key, JWT secret, external API keys

# Frankfurt Supabase project — the dev Mumbai project stays in
# .env.example as a fallback. Get the values from the Frankfurt
# project's Settings → API pane.
VITE_SUPABASE_URL=https://<FRANKFURT_PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<FRANKFURT_ANON_KEY>

# Public URL of the Express orchestrator on Render. Take this from
# Render's web-service detail page (the *.onrender.com URL or the
# custom domain if you've attached one). The trailing slash is NOT
# allowed — the client appends `/api/...` directly.
VITE_API_URL=https://chaw-server.onrender.com
