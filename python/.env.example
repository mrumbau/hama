# python/.env.example — copy to python/.env (gitignored).
# ML service is internal-only; it does not hold external API keys.

ML_HOST=0.0.0.0
ML_PORT=8001
ML_WORKERS=2

REDIS_URL=redis://127.0.0.1:6379

# InsightFace model pack. buffalo_l = ArcFace 512-D + RetinaFace.
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_DET_SIZE=640

# Quality gate thresholds (Tag 4)
QUALITY_MIN_FACE_PX=112
QUALITY_MAX_BLUR_VAR=120
QUALITY_MAX_POSE_YAW_DEG=45
