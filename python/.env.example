# python/.env.example — copy to python/.env (gitignored).
# ML service is internal-only; it does not hold external API keys.

ML_HOST=0.0.0.0
ML_PORT=8001
ML_WORKERS=2

REDIS_URL=redis://127.0.0.1:6379

# InsightFace model pack. buffalo_l = ArcFace 512-D + RetinaFace.
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_DET_SIZE=640

# Quality gate thresholds. Reasons returned to the operator UI:
#   face_too_small             · QUALITY_MIN_FACE_PX        — short edge of the face bbox
#   too_blurry                 · QUALITY_MIN_BLUR_VAR       — Laplacian variance on the EYE REGION (HIGHER = sharper)
#   pose_extreme               · QUALITY_MAX_POSE_YAW_DEG   — |yaw| derived from 5-point landmarks
#   low_confidence_detection   · DETECTOR_QUALITY_MIN       — RetinaFace det_score floor for enrolment
#
# QUALITY_MIN_BLUR_VAR is a heuristic on the eye-region crop (1.6×iod horizontal
# × 1.0×iod vertical, centred on the eye-landmark midpoint). 30 is the final
# iteration after empirical observation that real iPhone computational-photography
# selfies produce eye-region variance ~80–200 despite passing visual inspection;
# earlier values (150 in v2, 40 in v1, 80 in Tag 4) were too strict for modern
# smartphone output. The detector-confidence floor (0.75) catches RetinaFace
# mis-detections (hands, occluded faces, extreme low light) before they enrol.
# See DECISIONS.md D-016 for the full calibration history; Tag 13 substitutes
# with an empirical threshold from a 30-selfie histogram (EVALUATION.md backlog).
QUALITY_MIN_FACE_PX=112
QUALITY_MIN_BLUR_VAR=30
QUALITY_MAX_POSE_YAW_DEG=55
DETECTOR_QUALITY_MIN=0.75

# Detector admission floor (RetinaFace → keep face if score >= this).
# Permissive on purpose — Patrol Mode needs to see marginal faces in
# low-light webcam frames; the enrolment-side gate uses DETECTOR_QUALITY_MIN.
DETECTOR_MIN_SCORE=0.5
