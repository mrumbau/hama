# python/.env.example — copy to python/.env (gitignored).
# ML service is internal-only; it does not hold external API keys.

ML_HOST=0.0.0.0
ML_PORT=8001
ML_WORKERS=2

REDIS_URL=redis://127.0.0.1:6379

# InsightFace model pack. buffalo_s = MBF-ArcFace 512-D + RetinaFace,
# fits in 512MB RAM (Render Starter). buffalo_l is more accurate but
# needs ~2GB. Embedding dim stays 512 — schema unchanged.
INSIGHTFACE_MODEL_PACK=buffalo_s
INSIGHTFACE_DET_SIZE=640

# Quality gate thresholds. Reasons returned to the operator UI:
#   face_too_small             · QUALITY_MIN_FACE_PX        — short edge of the face bbox
#   pose_extreme               · QUALITY_MAX_POSE_YAW_DEG   — |yaw| derived from 5-point landmarks
#   low_confidence_detection   · DETECTOR_QUALITY_MIN       — RetinaFace det_score floor for enrolment
#
# QUALITY_MIN_BLUR_VAR is disabled (D-017). Default 0.0 means the
# `too_blurry` reason never triggers — the discriminative range
# between sharp and slightly-soft smartphone selfies is only ~5-15
# Laplacian-variance points, which is too narrow for robust
# classification. `det_score` covers the same failure modes with a
# wider margin. The eye-region variance is still computed and
# reported in metrics for the Tag 13 FIQA benchmark. Set > 0 only to
# re-enable for legacy DSLR-quality images.
QUALITY_MIN_FACE_PX=112
QUALITY_MIN_BLUR_VAR=0.0
QUALITY_MAX_POSE_YAW_DEG=55
DETECTOR_QUALITY_MIN=0.75

# Detector admission floor (RetinaFace → keep face if score >= this).
# Permissive on purpose — Patrol Mode needs to see marginal faces in
# low-light webcam frames; the enrolment-side gate uses DETECTOR_QUALITY_MIN.
DETECTOR_MIN_SCORE=0.5
