# python/.env.example — copy to python/.env (gitignored).
# ML service is internal-only; it does not hold external API keys.

ML_HOST=0.0.0.0
ML_PORT=8001
ML_WORKERS=2

REDIS_URL=redis://127.0.0.1:6379

# InsightFace model pack. buffalo_l = ArcFace 512-D + RetinaFace.
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_DET_SIZE=640

# Quality gate thresholds (Tag 4). Reasons returned to the operator UI:
#   face_too_small  · QUALITY_MIN_FACE_PX        — short edge of the face bbox
#   too_blurry      · QUALITY_MIN_BLUR_VAR       — Laplacian-variance on the crop (HIGHER = sharper)
#   pose_extreme    · QUALITY_MAX_POSE_YAW_DEG   — |yaw| derived from 5-point landmarks
QUALITY_MIN_FACE_PX=112
QUALITY_MIN_BLUR_VAR=80
QUALITY_MAX_POSE_YAW_DEG=45

# Detector confidence floor (RetinaFace → keep face if score >= this)
DETECTOR_MIN_SCORE=0.5
