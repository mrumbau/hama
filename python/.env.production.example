# python/.env.production.example
#
# Copy to Render's env panel for the `chaw-ml` web service. The Python
# ML service is internal-only — no external API keys live here.
# Render exposes the public chaw-ml URL only so the chaw-server box
# can reach it; not for browser traffic.

# Render injects PORT. The Dockerfile binds 0.0.0.0:$PORT; do NOT set
# ML_PORT here. ML_HOST stays 0.0.0.0 (anything else won't accept
# Render's edge connections).
ML_HOST=0.0.0.0

# Render Standard is single-vCPU + 2GB RAM. Two uvicorn workers would
# double the InsightFace memory (each loads its own pack) and trade off
# blocking-CPU time rather than gaining real concurrency. Stick to ONE
# worker; the 5-10 fps Patrol Mode + ≤1 RPS Sniper Mode demand is well
# under what a single buffalo_l worker delivers.
ML_WORKERS=1

# ── Redis (Render-managed Key-Value) ─────────────────────────────────────────
# Same Redis instance the Express server uses — ByteTrack state +
# per-track embedding cache. Render exposes the managed URL via
# REDIS_URL automatically when you attach the Key-Value addon.
REDIS_URL=<RENDER_REDIS_URL>

# ── InsightFace ─────────────────────────────────────────────────────────────
# buffalo_l on the 2GB Render Standard tier (resident set ~1.2–1.5GB
# with one uvicorn worker). The Dockerfile bakes the ~280MB pack into
# the image at build time so cold-start does not download per boot.
# Drop to buffalo_s on Starter (512MB) — ~5% TAR loss, smaller MBF
# ArcFace + dropped landmark/genderage nets, same 512-d embedding so
# the pgvector schema is unchanged. Re-run scripts/re-enroll-all.ts on
# any switch.
INSIGHTFACE_MODEL_PACK=buffalo_l
INSIGHTFACE_DET_SIZE=640

# ── Quality gate ────────────────────────────────────────────────────────────
QUALITY_MIN_FACE_PX=112
QUALITY_MIN_BLUR_VAR=0.0
QUALITY_MAX_POSE_YAW_DEG=55
DETECTOR_QUALITY_MIN=0.75
DETECTOR_MIN_SCORE=0.5

# ── Tracking (Tag 7, ADR-3) ─────────────────────────────────────────────────
BYTETRACK_FRAME_RATE=10
TRACKER_STATE_TTL_S=60
TRACK_EMBED_TTL_S=30
TRACK_EMBED_MAX_AGE_S=2.0
